{
  "allOf": [
    {
      "$ref": "https://json.schemastore.org/appsettings.json"
    }
  ],
  "properties": {
    "Cors": {
      "type": [
        "object",
        "null"
      ],
      "properties": {
        "PolicyName": {
          "type": "string",
          "description": "CORS policy name registered in the pipeline.",
          "default": "XBOLPolicy"
        },
        "AcceptedOrigins": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Origins allowed to call the API (exact match)."
        }
      },
      "description": "Cross-origin policy registered in the HTTP pipeline.",
      "required": [
        "PolicyName",
        "AcceptedOrigins"
      ]
    },
    "GcipAuth": {
      "type": [
        "object",
        "null"
      ],
      "properties": {
        "ProjectId": {
          "type": [
            "string",
            "null"
          ],
          "description": "Firebase project ID.",
          "default": "boletera-qa"
        },
        "ServiceAccountJsonPath": {
          "type": [
            "string",
            "null"
          ],
          "description": "Path to a Firebase service account JSON file."
        },
        "ServiceAccountJson": {
          "type": [
            "string",
            "null"
          ],
          "description": "Firebase service account JSON content."
        }
      },
      "description": "Firebase Admin SDK authentication settings for Client root authentication.",
      "required": [
        "ProjectId"
      ]
    },
    "TicketingClient": {
      "type": [
        "object",
        "null"
      ],
      "properties": {
        "BaseAddress": {
          "type": "string",
          "description": "Base URL for the ticketing API",
          "default": "https://dev-api.pwrticket.mx/ticketing/"
        }
      },
      "description": "Ticketing API client settings.",
      "required": [
        "BaseAddress"
      ]
    },
    "SearchSettings": {
      "type": [
        "object",
        "null"
      ],
      "properties": {
        "MatchRatio": {
          "type": "integer",
          "default": 70
        }
      },
      "description": "Fuzzy search matching parameters."
    },
    "EventsTrackingSettings": {
      "type": [
        "object",
        "null"
      ],
      "properties": {
        "ViewDuplicateMinutes": {
          "type": "integer",
          "default": 30
        },
        "IpRateLimitMinutes": {
          "type": "integer",
          "default": 1
        },
        "MaxViewsPerIpPerMinute": {
          "type": "integer",
          "default": 10
        }
      },
      "description": "Events view-tracking rate limits and deduplication."
    }
  },
  "type": "object"
}
