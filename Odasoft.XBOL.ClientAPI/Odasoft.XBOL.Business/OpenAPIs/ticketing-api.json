    "/api/hold-seats": {
      "post": {
        "tags": [
          "Hold"
        ],
        "summary": "Asynchronously holds the specified seats for an event and returns a token representing the hold.",
        "description": "This method reserves the requested seats for a limited time, allowing further actions\r\n            such as purchase or release. If the event is not found or the seat information is invalid, the operation may\r\n            fail. Exception handling should be implemented to manage such cases appropriately.",
        "operationId": "HoldSeatsAsync",
        "requestBody": {
          "description": "The request containing the event identifier and the collection of seat identifiers to be held. The event\r\n            identifier must correspond to an existing event, and the seat identifiers must be valid for that event.",
          "content": {
            "application/json-patch+json": {
              "schema": {
                "allOf": [
                  {
                    "$ref": "#/components/schemas/HoldSeatsRequest"
                  }
                ]
              }
            },
            "application/json": {
              "schema": {
                "allOf": [
                  {
                    "$ref": "#/components/schemas/HoldSeatsRequest"
                  }
                ]
              }
            },
            "text/json": {
              "schema": {
                "allOf": [
                  {
                    "$ref": "#/components/schemas/HoldSeatsRequest"
                  }
                ]
              }
            },
            "application/*+json": {
              "schema": {
                "allOf": [
                  {
                    "$ref": "#/components/schemas/HoldSeatsRequest"
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/HoldToken"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HoldToken"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/HoldToken"
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": [
          "Hold"
        ],
        "summary": "Retrieves the hold token associated with the specified token string.",
        "description": "This method is asynchronous and may involve network calls to retrieve the hold token.\r\n            Ensure that the hold token is valid before calling this method.",
        "operationId": "GetHoldTokenAsync",
        "parameters": [
          {
            "name": "holdToken",
            "in": "query",
            "description": "The hold token string used to identify the specific hold request. This parameter cannot be null or empty.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/HoldToken"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HoldToken"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/HoldToken"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Hold"
        ],
        "summary": "Releases the hold on seats associated with the specified hold token.",
        "description": "This method is asynchronous and should be awaited. It communicates with the seat\r\n            management service to release the hold, and may throw exceptions if the hold token is invalid or if service\r\n            errors occur.",
        "operationId": "ReleaseHoldSeatsAsync",
        "parameters": [
          {
            "name": "holdToken",
            "in": "query",
            "description": "The token that identifies the hold to be released. This value must be a valid, non-null hold token.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/HoldToken"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HoldToken"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/HoldToken"
                }
              }
            }
          }
        }
      }
