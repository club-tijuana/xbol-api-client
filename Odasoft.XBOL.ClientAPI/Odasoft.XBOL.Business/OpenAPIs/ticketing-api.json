    "/api/events": {
      "get": {
        "tags": [
          "Events"
        ],
        "summary": "Retrieves a paginated list of events filtered by venue, category, date range, and search criteria.",
        "operationId": "GetEventsAsync",
        "parameters": [
          {
            "name": "venues",
            "in": "query",
            "description": "A comma-separated list of venue identifiers used to filter the events. If null or empty, events from all\r\n            venues are included.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "categories",
            "in": "query",
            "description": "A comma-separated list of event category names used to filter the events. If null or empty, events from all\r\n            categories are included.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "startDate",
            "in": "query",
            "description": "The start date and time for filtering events. Only events occurring on or after this date are included. If\r\n            null, no lower date bound is applied.",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "endDate",
            "in": "query",
            "description": "The end date and time for filtering events. Only events occurring on or before this date are included. If\r\n            null, no upper date bound is applied.",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "search",
            "in": "query",
            "description": "A search term used to filter events by name or description. If null or empty, no search filtering is\r\n            applied.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sortBy",
            "in": "query",
            "description": "The field by which to sort the events. Defaults to \"dateTime\" if not specified.",
            "schema": {
              "type": "string",
              "default": "dateTime"
            }
          },
          {
            "name": "descending",
            "in": "query",
            "description": "Indicates whether the results should be sorted in descending order. Set to true to sort\r\n            descending; otherwise, ascending.",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "The page number of results to retrieve. Must be greater than zero.",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 1
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "description": "The maximum number of events to include in a single page of results. Must be greater than zero.",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 10
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/EventListItemPagedResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EventListItemPagedResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/EventListItemPagedResponse"
                }
              }
            }
          }
        }
      }
    },
